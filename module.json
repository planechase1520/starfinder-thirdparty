{
  "id": "starfinder-thirdparty",
  "title": "Starfinder Third Party Library",
  "description": "A reusable content-management module that allows a GM to import and organize legally owned third-party Starfinder 1E content into Foundry VTT. Supports CSV, JSON, and OCR text import pipelines with full validation and compendium management.",
  "version": "1.4.0",
  "authors": [
    {
      "name": "Starfinder Third Party Library Contributors",
      "discord": "",
      "url": ""
    }
  ],
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "relationships": {
    "systems": [
      {
        "id": "sfrpg",
        "type": "system",
        "compatibility": {
          "minimum": "0.25.0"
        }
      }
    ]
  },
  "esmodules": [
    "scripts/starfinder-thirdparty.js"
  ],
  "styles": [
    "styles/starfinder-thirdparty.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "packs": [
