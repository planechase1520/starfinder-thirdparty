{{!-- Content Browser — Milestone 2
     Database-backed browser with search, filter, sort, detail panel, and export --}}

<div class="sf3pl-browser">

  {{!-- Top toolbar --}}
  <div class="sf3pl-browser-toolbar">
    <div class="sf3pl-search-wrap">
      <i class="fas fa-search sf3pl-search-icon"></i>
      <input type="text" id="sf3pl-search" class="sf3pl-search-input"
        value="{{filter.searchText}}" placeholder="Search by name, publisher, source book, tags…">
    </div>

    <div class="sf3pl-toolbar-actions">
      {{#if hasChecked}}
      <span class="sf3pl-checked-badge">{{checkedCount}} selected</span>
      <button id="sf3pl-btn-bulk-delete" class="sf3pl-btn sf3pl-btn-danger sf3pl-btn-sm">
        <i class="fas fa-trash"></i> Delete Selected
      </button>
      {{/if}}

      <div class="sf3pl-export-group">
        <button id="sf3pl-btn-export-json" class="sf3pl-btn sf3pl-btn-secondary sf3pl-btn-sm" title="Export to JSON">
          <i class="fas fa-file-code"></i> JSON
        </button>
        <button id="sf3pl-btn-export-csv" class="sf3pl-btn sf3pl-btn-secondary sf3pl-btn-sm" title="Export to CSV">
          <i class="fas fa-file-csv"></i> CSV
        </button>
      </div>

      <button id="sf3pl-btn-refresh" class="sf3pl-btn sf3pl-btn-secondary sf3pl-btn-sm" title="Reload from database">
        <i class="fas fa-sync-alt"></i>
      </button>
    </div>
  </div>

  {{!-- M3 Conversion Toolbar --}}
  <div class="sf3pl-conversion-toolbar">
    <span class="sf3pl-conversion-label"><i class="fas fa-cogs"></i> Compendium</span>
    <div class="sf3pl-conversion-actions">
      <button id="sf3pl-btn-convert-selected" class="sf3pl-btn sf3pl-btn-primary sf3pl-btn-sm"
        title="Convert checked records to Foundry documents" {{#unless hasChecked}}disabled{{/unless}}>
        <i class="fas fa-wand-magic-sparkles"></i> Convert Selected
      </button>
      <button id="sf3pl-btn-convert-category" class="sf3pl-btn sf3pl-btn-primary sf3pl-btn-sm"
        title="Convert all records in the selected record's category" {{#unless hasSelection}}disabled{{/unless}}>
        <i class="fas fa-layer-group"></i> Convert Category
      </button>
      <button id="sf3pl-btn-build-compendium" class="sf3pl-btn sf3pl-btn-success sf3pl-btn-sm"
        title="Build compendium from current filtered records" {{#if isEmpty}}disabled{{/if}}>
        <i class="fas fa-book-bookmark"></i> Build Compendium
      </button>
      <button id="sf3pl-btn-rebuild-compendium" class="sf3pl-btn sf3pl-btn-warning sf3pl-btn-sm"
        title="Rebuild compendium — overwrites all existing entries" {{#if isEmpty}}disabled{{/if}}>
        <i class="fas fa-rotate"></i> Rebuild
      </button>
    </div>
  </div>

  <div class="sf3pl-browser-body">

    {{!-- Sidebar filters --}}
    <aside class="sf3pl-filter-sidebar">

      <div class="sf3pl-filter-section">
        <div class="sf3pl-filter-heading">
          Category
          <button id="sf3pl-btn-clear-filter" class="sf3pl-btn-link">Clear All</button>
        </div>
        {{#if categoryFilterOptions}}
        <ul class="sf3pl-category-list">
          {{#each categoryFilterOptions}}
          <li>
            <label class="sf3pl-category-item {{#if active}}active{{/if}}">
              <input type="checkbox" class="sf3pl-category-filter"
                value="{{value}}" {{#if active}}checked{{/if}}>
              <span class="sf3pl-category-label">{{label}}</span>
              <span class="sf3pl-category-count">{{count}}</span>
            </label>
          </li>
          {{/each}}
        </ul>
        {{else}}
        <p class="sf3pl-filter-empty">No content imported yet.</p>
        {{/if}}
      </div>

      {{#if publisherOptions}}
      <div class="sf3pl-filter-section">
        <div class="sf3pl-filter-heading">Publisher</div>
        <select id="sf3pl-filter-publisher" class="sf3pl-filter-select">
          <option value="">— All Publishers —</option>
          {{#each publisherOptions}}
          <option value="{{value}}" {{#if (eq value ../filter.publisher)}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
      {{/if}}

      {{#if sourceBookOptions}}
      <div class="sf3pl-filter-section">
        <div class="sf3pl-filter-heading">Source Book</div>
        <select id="sf3pl-filter-sourcebook" class="sf3pl-filter-select">
          <option value="">— All Books —</option>
          {{#each sourceBookOptions}}
          <option value="{{value}}" {{#if (eq value ../filter.sourceBook)}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
      {{/if}}

      {{#if tagOptions}}
      <div class="sf3pl-filter-section">
        <div class="sf3pl-filter-heading">Tag</div>
        <select id="sf3pl-filter-tag" class="sf3pl-filter-select">
          <option value="">— All Tags —</option>
          {{#each tagOptions}}
          <option value="{{value}}" {{#if (eq value ../filter.tag)}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
      {{/if}}

    </aside>

    {{!-- Main content area --}}
    <div class="sf3pl-browser-main">

      {{#if isEmpty}}
      <div class="sf3pl-empty-state">
        <i class="fas fa-inbox sf3pl-empty-icon"></i>
        <h3>No Content Yet</h3>
        <p>Use the <strong>Import Wizard</strong> to import your first records.</p>
        <p class="sf3pl-hint">Toolbar → <i class="fas fa-file-import"></i> or <code>game.modules.get('starfinder-thirdparty').api.openImportWizard()</code></p>
      </div>
      {{else}}

      <div class="sf3pl-table-header">
        <span class="sf3pl-result-count">{{filteredCount}} of {{totalCount}} records</span>
      </div>

      {{!-- Record table --}}
      <div class="sf3pl-table-wrap">
        <table class="sf3pl-table sf3pl-browser-table">
          <thead>
            <tr>
              <th class="sf3pl-col-check">
                <input type="checkbox" id="sf3pl-select-all" title="Select all visible">
              </th>
              <th class="sf3pl-col-icon"></th>
              <th class="sf3pl-sortable" data-sort="name">
                Name
                {{#if sort.isAscName}}<i class="fas fa-sort-up"></i>{{else if sort.isDescName}}<i class="fas fa-sort-down"></i>{{else}}<i class="fas fa-sort sf3pl-sort-faint"></i>{{/if}}
              </th>
              <th class="sf3pl-sortable" data-sort="category">Category</th>
              <th class="sf3pl-sortable" data-sort="sourceBook">Source Book</th>
              <th class="sf3pl-sortable" data-sort="publisher">Publisher</th>
              <th>Level</th>
              <th>Tags</th>
              <th>Imported</th>
            </tr>
          </thead>
          <tbody>
            {{#each rows}}
            <tr class="sf3pl-row {{#if isSelected}}sf3pl-row-selected{{/if}}" data-id="{{id}}">
              <td class="sf3pl-col-check">
                <input type="checkbox" class="sf3pl-row-check" data-id="{{id}}" {{#if isChecked}}checked{{/if}}>
              </td>
              <td class="sf3pl-col-icon">
                <i class="fas {{categoryIcon}} sf3pl-type-icon" title="{{categoryLabel}}"></i>
              </td>
              <td class="sf3pl-col-name"><strong>{{name}}</strong></td>
              <td class="sf3pl-col-cat">{{categoryLabel}}</td>
              <td class="sf3pl-col-book">{{sourceBook}}</td>
              <td class="sf3pl-col-pub">{{publisher}}</td>
              <td class="sf3pl-col-level">{{level}}</td>
              <td class="sf3pl-col-tags">{{#if tags}}<span class="sf3pl-tags-cell">{{tags}}</span>{{else}}—{{/if}}</td>
              <td class="sf3pl-col-date">{{importedDate}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>

      {{#unless rows}}
      <p class="sf3pl-empty-msg"><i class="fas fa-filter"></i> No records match the current filters.</p>
      {{/unless}}

      {{/if}}{{!-- /.isEmpty else --}}
    </div>{{!-- /.sf3pl-browser-main --}}

    {{!-- Detail panel --}}
    {{#if hasSelection}}
    <aside class="sf3pl-detail-panel">
      {{#if detailPanel}}
      <div class="sf3pl-detail-header">
        <i class="fas {{detailPanel.categoryIcon}} sf3pl-detail-icon"></i>
        <div>
          <h3 class="sf3pl-detail-name">{{detailPanel.name}}</h3>
          <span class="sf3pl-detail-category">{{detailPanel.categoryLabel}}</span>
        </div>
      </div>

      <div class="sf3pl-detail-fields">

        <div class="sf3pl-detail-field">
          <span class="sf3pl-detail-label">Source Book</span>
          <span class="sf3pl-detail-value">{{detailPanel.sourceBook}}</span>
        </div>

        <div class="sf3pl-detail-field">
          <span class="sf3pl-detail-label">Publisher</span>
          <span class="sf3pl-detail-value">{{detailPanel.publisher}}</span>
        </div>

        <div class="sf3pl-detail-field">
          <span class="sf3pl-detail-label">Author</span>
          <span class="sf3pl-detail-value">{{detailPanel.author}}</span>
        </div>

        <div class="sf3pl-detail-field">
          <span class="sf3pl-detail-label">Page</span>
          <span class="sf3pl-detail-value">{{detailPanel.pageNumber}}</span>
        </div>

        <div class="sf3pl-detail-field">
          <span class="sf3pl-detail-label">Imported</span>
          <span class="sf3pl-detail-value">{{detailPanel.importedDate}} via {{detailPanel.importMethod}}</span>
        </div>

        {{!-- Tags --}}
        {{#if detailPanel.editingNotes}}
        <div class="sf3pl-detail-field sf3pl-field-full">
          <span class="sf3pl-detail-label">Tags <span class="sf3pl-optional">(comma-separated)</span></span>
          <input type="text" id="sf3pl-tags-editor" value="{{detailPanel.tagsBuffer}}" class="sf3pl-tags-input">
        </div>
        {{else}}
        <div class="sf3pl-detail-field sf3pl-field-full">
          <span class="sf3pl-detail-label">Tags</span>
          <span class="sf3pl-detail-value">{{detailPanel.tags}}</span>
        </div>
        {{/if}}

        {{!-- Notes --}}
        {{#if detailPanel.editingNotes}}
        <div class="sf3pl-detail-field sf3pl-field-full">
          <span class="sf3pl-detail-label">Notes</span>
          <textarea id="sf3pl-notes-editor" class="sf3pl-notes-editor" rows="4">{{detailPanel.notesBuffer}}</textarea>
        </div>
        {{else}}
        <div class="sf3pl-detail-field sf3pl-field-full">
          <span class="sf3pl-detail-label">Notes</span>
          <span class="sf3pl-detail-value sf3pl-notes-display">{{#if detailPanel.notes}}{{detailPanel.notes}}{{else}}<em>No notes</em>{{/if}}</span>
        </div>
        {{/if}}

      </div>

      {{!-- Raw content collapsible --}}
      <details class="sf3pl-raw-content">
        <summary><i class="fas fa-code"></i> Raw Content</summary>
        <pre class="sf3pl-json-view">{{detailPanel.rawContentJson}}</pre>
      </details>

      {{!-- Detail actions --}}
      <div class="sf3pl-detail-actions">
        {{#if detailPanel.editingNotes}}
        <button id="sf3pl-btn-save-notes" class="sf3pl-btn sf3pl-btn-primary sf3pl-btn-sm">
          <i class="fas fa-save"></i> Save
        </button>
        <button id="sf3pl-btn-cancel-notes" class="sf3pl-btn sf3pl-btn-secondary sf3pl-btn-sm">
          Cancel
        </button>
        {{else}}
        <button id="sf3pl-btn-edit-notes" class="sf3pl-btn sf3pl-btn-secondary sf3pl-btn-sm">
          <i class="fas fa-edit"></i> Edit Notes &amp; Tags
        </button>
        <button id="sf3pl-btn-download-raw" class="sf3pl-btn sf3pl-btn-secondary sf3pl-btn-sm">
          <i class="fas fa-download"></i> Raw JSON
        </button>
        <button id="sf3pl-btn-delete" class="sf3pl-btn sf3pl-btn-danger sf3pl-btn-sm">
          <i class="fas fa-trash"></i> Delete
        </button>
        {{/if}}
      </div>

      {{/if}}{{!-- /.detailPanel --}}
    </aside>
    {{/if}}{{!-- /.hasSelection --}}

  </div>{{!-- /.sf3pl-browser-body --}}

</div>{{!-- /.sf3pl-browser --}}
