{
  "schemaVersion": "3.0.0",
  "category": "npc",
  "description": "Field mappings from rawContent keys to SFRPG npc2 Actor system data paths.",
  "fields": [
    { "source": "cr",              "target": "details.cr",                  "type": "string",  "default": "1" },
    { "source": "challengeRating", "target": "details.cr",                  "type": "string",  "default": "1" },
    { "source": "xp",              "target": "details.xp.value",            "type": "number",  "default": 400 },
    { "source": "alignment",       "target": "details.alignment",           "type": "string",  "default": "N" },
    { "source": "size",            "target": "details.size",                "type": "string",  "default": "medium" },
    { "source": "creatureType",    "target": "details.type",                "type": "string",  "default": "" },
    { "source": "type",            "target": "details.type",                "type": "string",  "default": "" },
    { "source": "creatureSubtype", "target": "details.subtype",             "type": "string",  "default": "" },
    { "source": "subtype",         "target": "details.subtype",             "type": "string",  "default": "" },
    { "source": "eac",             "target": "attributes.eac.value",        "type": "number",  "default": 10 },
    { "source": "kac",             "target": "attributes.kac.value",        "type": "number",  "default": 10 },
    { "source": "hp",              "target": "attributes.hp.max",           "type": "number",  "default": 6 },
    { "source": "fort",            "target": "attributes.fort.bonus",       "type": "number",  "default": 0 },
    { "source": "ref",             "target": "attributes.reflex.bonus",     "type": "number",  "default": 0 },
    { "source": "will",            "target": "attributes.will.bonus",       "type": "number",  "default": 0 },
    { "source": "init",            "target": "attributes.init.value",       "type": "number",  "default": 0 },
    { "source": "initiative",      "target": "attributes.init.value",       "type": "number",  "default": 0 },
    { "source": "bab",             "target": "attributes.bab",              "type": "number",  "default": 0 },
    { "source": "str",             "target": "abilities.str.value",         "type": "number",  "default": 10 },
    { "source": "dex",             "target": "abilities.dex.value",         "type": "number",  "default": 10 },
    { "source": "con",             "target": "abilities.con.value",         "type": "number",  "default": 10 },
    { "source": "int",             "target": "abilities.int.value",         "type": "number",  "default": 10 },
    { "source": "wis",             "target": "abilities.wis.value",         "type": "number",  "default": 10 },
    { "source": "cha",             "target": "abilities.cha.value",         "type": "number",  "default": 10 },
    { "source": "speed",           "target": "speed.value",                 "type": "number",  "default": 30 },
    { "source": "senses",          "target": "traits.senses",               "type": "string",  "default": "" },
    { "source": "immunities",      "target": "traits.immunities.value",     "type": "array",   "default": [] },
    { "source": "languages",       "target": "traits.languages.value",      "type": "array",   "default": [] },
    { "source": "dr",              "target": "traits.dr",                   "type": "string",  "default": "" },
    { "source": "description",     "target": "details.biography.value",     "type": "string",  "default": "" }
  ]
}
